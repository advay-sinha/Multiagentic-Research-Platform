# ============================================================================
# Autonomous Multi-Agentic Research Platform — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values you need.
# Only the "Active" variables are read by the current codebase.
# "Reserved" variables are placeholders for future integrations.
# ============================================================================

# ── Active Variables (read by backend/app/ and frontend) ────────────────────

# LLM Provider (gemini | openai | stub)
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=
# Popular :free models (Gemma, Llama, Qwen) share a global daily pool and are
# often saturated → 429 upstream. gpt-oss-120b:free has more headroom.
# Alternates: z-ai/glm-4.5-air:free, nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_MODEL=openai/gpt-oss-120b:free
# Per-agent provider split (comma-separated agent=provider pairs).
# Alternates providers across the sequential Planner→Writer→Critic→Verifier
# flow to avoid single-provider rate-limit clustering.
AGENT_PROVIDER_MAP=planner=gemini,writer=openrouter,critic=gemini,verifier=openrouter

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Embeddings (Gemini embedContent API)
# gemini-embedding-002 preferred; code falls back to gemini-embedding-001 on 404.
EMBEDDING_MODEL=models/gemini-embedding-002
EMBEDDING_DIM=768
# Order of embedding providers to try. Default is Gemini only — on 429/402/403
# the caller falls back to the in-memory DOCUMENT_STORE (TF-IDF keyword search)
# so ingest/retrieval still works without any vector calls. Opt into fastembed
# (BAAI/bge-base-en-v1.5, 768-dim, offline after first download) by setting
# EMBED_PROVIDER_ORDER=gemini,local.
EMBED_PROVIDER_ORDER=gemini
LOCAL_EMBED_MODEL=BAAI/bge-base-en-v1.5
# Gemini 429 retry budget. 1 = 2 attempts total (fail fast → in-memory fallback).
GEMINI_EMBED_RETRIES=1

# PostgreSQL + pgvector (optional — app runs in stub mode without it)
DATABASE_URL=

# MongoDB (optional — enables auth, per-user query history, evidence cache)
MONGO_URI=
MONGO_DB=mars

# JWT auth (change this in production!)
JWT_SECRET=dev-insecure-jwt-secret-change-me
JWT_EXPIRE_HOURS=168

# RAG cache TTL for evidence reuse on identical past queries (seconds).
RAG_CACHE_TTL_SECONDS=604800

# Search Providers (optional — enables /v1/search endpoint and retriever web fallback)
BING_API_KEY=
SERPAPI_KEY=

# Web fallback: if primary retrieval is empty or top score < this threshold,
# Retriever auto-runs SerpAPI (preferred) or Bing and merges web rows as evidence.
# Requires SERPAPI_KEY or BING_API_KEY. Set to 0 to disable the fallback.
WEB_FALLBACK_SCORE_MIN=0.3

# CORS (backend allows requests from this origin)
CORS_ALLOW_ORIGIN=http://localhost:3000

# Frontend API base URL (used at Next.js build time)
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Retrieval strategy:
#   hybrid      — web search + embed/index + vector search (heavy embed RPM use)
#   web_only    — web search, extracted text used directly as evidence (default;
#                 zero embedding calls during chat)
#   vector_only — skip web, only search pgvector store
#   off         — no retrieval (LLM-only)
RETRIEVAL_MODE=web_only

# Agent orchestration. Each iteration = writer+critic+verifier (3 LLM calls).
# Keep at 1 on free tiers. Bump only if you have paid-tier RPM headroom.
MAX_AGENT_ITERATIONS=1
# Min gap between LLM calls (ms). Per-provider defaults: gemini=6500,
# openrouter=6500, openai=2500. Set LLM_MIN_INTERVAL_MS_<PROVIDER> to override.
LLM_MIN_INTERVAL_MS=6500
# Provider cooldown after rate limits or invalid credentials/model errors.
# `Retry-After` is respected when the API returns it.
LLM_COOLDOWN_SECONDS_429=60
LLM_COOLDOWN_SECONDS_OPENROUTER_429=90
LLM_COOLDOWN_SECONDS_503=15
LLM_COOLDOWN_SECONDS_401=300
LLM_COOLDOWN_SECONDS_403=300
LLM_COOLDOWN_SECONDS_404=300

# Logging
LOG_LEVEL=info

