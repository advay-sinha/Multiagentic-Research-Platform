# ============================================================================
# Autonomous Multi-Agentic Research Platform — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values you need.
# Only the "Active" variables are read by the current codebase.
# "Reserved" variables are placeholders for future integrations.
# ============================================================================

# ── Active Variables (read by backend/app/ and frontend) ────────────────────

# LLM Provider (gemini | openai | stub)
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Embeddings (Gemini embedContent API)
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIM=768

# PostgreSQL + pgvector (optional — app runs in stub mode without it)
DATABASE_URL=

# Search Providers (optional — enables /v1/search endpoint)
BING_API_KEY=
SERPAPI_KEY=

# CORS (backend allows requests from this origin)
CORS_ALLOW_ORIGIN=http://localhost:3000

# Frontend API base URL (used at Next.js build time)
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Agent orchestration
MAX_AGENT_ITERATIONS=5

# Logging
LOG_LEVEL=info

# ── Reserved / Future Variables (not yet wired) ────────────────────────────

# APP_ENV=
# APP_NAME=
